    {
      "name": "04 - Transactions",
      "item": [
        {
          "name": "Transferencia valida (201)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/transactions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountId\": {{faberAccountId}},\n  \"toAccountId\": {{toAccountId}},\n  \"amount\": 100,\n  \"note\": \"Prueba transferencia exitosa\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.test('Tiene id de transaccion', function () { pm.expect(json.transactionId).to.exist; });",
                  "pm.test('Incluye destinatario', function () { pm.expect(json.toAccount.ownerName).to.be.a('string').and.not.empty; });",
                  "pm.test('Incluye monto enviado y saldo restante', function () {",
                  "  pm.expect(json.amountSent).to.be.a('number');",
                  "  pm.expect(json.fromAccount.balanceAfter).to.be.a('number');",
                  "});",
                  "if (json.transactionId) { pm.collectionVariables.set('lastTransactionId', String(json.transactionId)); }"
                ]
              }
            }
          ]
        },
