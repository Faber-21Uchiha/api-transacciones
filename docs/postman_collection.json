    {
      "name": "03 - Accounts",
      "item": [
        {
          "name": "Mis cuentas (200)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/accounts/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Retorna arreglo', function () { pm.expect(json).to.be.an('array'); });",
                  "pm.test('Tiene al menos una cuenta', function () { pm.expect(json.length).to.be.greaterThan(0); });",
                  "if (Array.isArray(json) && json.length > 0) {",
                  "  pm.collectionVariables.set('faberAccountId', String(json[0].id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Mis cuentas sin token (401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/accounts/me"
          },
          "event": [
            {
              "listen": "test",
